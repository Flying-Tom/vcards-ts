    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.57.0",
    "vcards-js": "^2.10.0",
    "vinyl": "^3.0.1"
  },
  "ava": {
    "typescript": {
      "rewritePaths": {
        "src/": "dist/"
      },
      "compile": false,
      "extensions": [
        "ts"
      ]
    }
  }
