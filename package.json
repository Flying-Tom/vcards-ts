  "license": "MIT",
  "private": true,
  "devDependencies": {
    "@ava/typescript": "^6.0.0",
    "@eslint/js": "^10.0.1",
    "@types/google-libphonenumber": "^7.4.30",
    "@types/gulp": "^4.0.17",
    "@types/gulp-concat": "^0.0.37",
    "@types/gulp-rename": "^2.0.6",
    "@types/gulp-util": "^3.0.41",
    "@types/gulp-zip": "^4.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.0.10",
    "@types/through2": "^2.0.41",
    "@types/vcards-js": "^2.10.5",
    "@types/vinyl": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "ava": "^6.4.0",
    "del": "^7.0.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globby": "^13.2.2",
    "google-libphonenumber": "^3.2.32",
    "gulp": "^4.0.2",
    "gulp-concat": "^2.6.1",
    "gulp-concat-folders": "^1.3.1",
    "gulp-rename": "^2.0.0",
    "gulp-typescript": "6.0.0-alpha.1",
    "gulp-util": "^3.0.8",
    "gulp-zip": "^5.1.0",
    "husky": "^9.1.7",
    "image-size": "^1.0.2",
    "joi": "^17.9.2",
    "js-yaml": "^4.1.0",
    "lint-staged": "^16.3.3",
