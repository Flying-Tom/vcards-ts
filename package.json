  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "pnpm run gulp build",
    "radicale": "pnpm run gulp radicale",
    "gulp": "gulp --require tsx/dist/loader.cjs -f src/gulpfile.ts --cwd ./",
    "test": "tsc && npx ava src/test.ts",
